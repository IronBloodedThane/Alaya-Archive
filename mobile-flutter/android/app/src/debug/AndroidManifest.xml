<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Debug-only override: permit cleartext HTTP so the app can talk to
         a local dev server (http://<lan-ip>:8080). Release builds inherit
         the platform default (HTTPS-only) because this manifest is only
         merged into debug builds. -->
    <application
        android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
