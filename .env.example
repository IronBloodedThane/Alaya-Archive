# API Configuration
PORT=8080
DATABASE_PATH=./data/alaya-archive.db
SECRET_KEY=generate-a-random-secret-key-here
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Email (optional - for email verification and password reset)
EMAIL_API_KEY=blank
EMAIL_FROM_EMAIL=noreply@alaya-archive.com

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Rate Limiting
RATE_LIMIT_ENABLED=true

# External metadata lookup (optional - books/manga via Google Books)
GOOGLE_BOOKS_API_KEY=change-me

# Google Cloud (for deployment)
GCP_PROJECT_ID=
GCP_REGION=us-central1
